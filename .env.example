# mcp-mirror credentials — 1Password reference pattern (recommended)
#
# This file is safe to commit because the values are not the secrets themselves
# — they are 1Password vault references in the form op://<vault>/<item>/<field>.
#
# Use:
#
#   1. Copy this file to .env
#   2. Update the op:// references to match your 1Password vault
#   3. Launch with `op run`:
#
#      op run --env-file=.env -- mcp-mirror
#
# `op run` resolves the references, injects the secrets into the subprocess
# environment, and clears them when the process exits. The secrets never
# touch disk.
#
# If you don't have the 1Password CLI installed, you can replace the
# `op://...` references with raw values in a local .env (which is gitignored).
# The mcp-mirror CLI's built-in .env loader will pick those up too.

# OpenAI API key — used for the wire-level LLM payload validation path.
OPENAI_API_KEY=op://Private/OpenAI/credential

# Arcade API key — used when mcp-mirror points at Arcade's hosted MCP server
# as the source-of-truth instead of the bundled reference server.
ARCADE_API_KEY=op://Employee/Arcade/credential
